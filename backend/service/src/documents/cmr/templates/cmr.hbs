<!DOCTYPE html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <title>CMR — {{tripNumber}}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', Arial, sans-serif; font-size: 11px; color: #1a1a1a; padding: 20mm 15mm; }
    h1 { font-size: 18px; text-align: center; color: #0A5C36; margin-bottom: 2px; }
    .subtitle { text-align: center; font-size: 10px; color: #666; margin-bottom: 16px; }
    .logo-row { text-align: center; margin-bottom: 8px; font-size: 14px; font-weight: bold; color: #0A5C36; letter-spacing: 2px; }

    table { width: 100%; border-collapse: collapse; margin-bottom: 12px; }
    td, th { border: 1px solid #999; padding: 5px 8px; vertical-align: top; }
    th { background: #f5f0ed; text-align: left; width: 35%; font-weight: 600; color: #333; }
    .section-header { background: #0A5C36; color: white; font-weight: 700; text-align: center; font-size: 11px; padding: 4px; }
    .section-header td { border-color: #0A5C36; }

    .two-col { display: flex; gap: 12px; margin-bottom: 12px; }
    .two-col > div { flex: 1; }

    .signatures { margin-top: 24px; page-break-inside: avoid; }
    .sig-grid { display: flex; justify-content: space-between; gap: 16px; margin-top: 8px; }
    .sig-box { flex: 1; border: 1px solid #ccc; border-radius: 4px; padding: 8px; min-height: 100px; text-align: center; }
    .sig-box .label { font-weight: 600; font-size: 10px; color: #666; margin-bottom: 4px; }
    .sig-box .name { font-weight: 700; font-size: 12px; margin-bottom: 8px; }
    .sig-box img { max-width: 180px; max-height: 70px; }

    .footer { margin-top: 20px; text-align: center; font-size: 9px; color: #999; border-top: 1px solid #ddd; padding-top: 8px; }
    .highlight { color: #0A5C36; font-weight: 600; }
  </style>
</head>
<body>
  <div class="logo-row">STRAWBOSS</div>
  <h1>SCRISOARE DE TRANSPORT CMR</h1>
  <p class="subtitle">Nr. cursă: <strong>{{tripNumber}}</strong> &mdash; {{date}}</p>

  <!-- 1. Expeditor -->
  <table>
    <tr class="section-header"><td colspan="2">1. EXPEDITOR</td></tr>
    <tr><th>Parcelă</th><td class="highlight">{{parcelName}}</td></tr>
    <tr><th>Adresă</th><td>{{senderAddress}}{{#if senderMunicipality}}, {{senderMunicipality}}{{/if}}</td></tr>
  </table>

  <!-- 2. Destinatar -->
  <table>
    <tr class="section-header"><td colspan="2">2. DESTINATAR</td></tr>
    <tr><th>Nume depozit</th><td class="highlight">{{destinationName}}</td></tr>
    <tr><th>Adresă</th><td>{{destinationAddress}}</td></tr>
  </table>

  <!-- 3. Transportator -->
  <table>
    <tr class="section-header"><td colspan="2">3. TRANSPORTATOR</td></tr>
    <tr><th>Camion</th><td>{{truckName}} &mdash; <strong>{{truckPlate}}</strong></td></tr>
    <tr><th>Șofer</th><td class="highlight">{{driverName}}</td></tr>
  </table>

  <!-- 4. Marfa -->
  <table>
    <tr class="section-header"><td colspan="2">4. MARFA TRANSPORTATĂ</td></tr>
    <tr><th>Nr. baloți</th><td class="highlight">{{baleCount}}</td></tr>
    <tr><th>Nr. încărcări</th><td>{{baleLoadCount}}</td></tr>
    <tr><th>Greutate brută (kg)</th><td>{{grossWeightKg}}</td></tr>
    <tr><th>Tară camion (kg)</th><td>{{tareWeightKg}}</td></tr>
    <tr><th>Greutate netă (kg)</th><td class="highlight">{{netWeightKg}}</td></tr>
    <tr><th>Nr. tichet cântar</th><td>{{weightTicketNumber}}</td></tr>
  </table>

  <!-- 5. Detalii cursă -->
  <table>
    <tr class="section-header"><td colspan="2">5. DETALII CURSĂ</td></tr>
    <tr><th>Plecare</th><td>{{departureAt}}</td></tr>
    <tr><th>Sosire</th><td>{{arrivalAt}}</td></tr>
    <tr><th>Livrare confirmată</th><td>{{deliveredAt}}</td></tr>
    <tr><th>Km plecare</th><td>{{departureOdometerKm}}</td></tr>
    <tr><th>Km sosire</th><td>{{arrivalOdometerKm}}</td></tr>
    <tr><th>Distanță (km)</th><td class="highlight">{{odometerDistanceKm}}</td></tr>
  </table>

  {{#if deliveryNotes}}
  <table>
    <tr class="section-header"><td colspan="2">6. OBSERVAȚII</td></tr>
    <tr><td colspan="2">{{deliveryNotes}}</td></tr>
  </table>
  {{/if}}

  <!-- Semnături -->
  <div class="signatures">
    <table>
      <tr class="section-header"><td colspan="2">{{#if deliveryNotes}}7{{else}}6{{/if}}. SEMNĂTURI</td></tr>
    </table>
    <div class="sig-grid">
      <div class="sig-box">
        <div class="label">EXPEDITOR</div>
        <div class="name">&nbsp;</div>
      </div>
      <div class="sig-box">
        <div class="label">ȘOFER / TRANSPORTATOR</div>
        <div class="name">{{driverName}}</div>
      </div>
      <div class="sig-box">
        <div class="label">PRIMITOR</div>
        <div class="name">{{receiverName}}</div>
        {{#if receiverSignatureUrl}}
        <img src="{{receiverSignatureUrl}}" alt="Semnătura primitorului" />
        {{/if}}
      </div>
    </div>
  </div>

  <div class="footer">
    Document generat automat de StrawBoss &mdash; {{date}} &mdash; Cursă {{tripNumber}}
  </div>
</body>
</html>
