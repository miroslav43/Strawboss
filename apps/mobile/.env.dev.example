# Copiază la .env.dev (gitignored): cp .env.dev.example .env.dev
#
# Expo include în bundle doar variabilele EXPO_PUBLIC_*.
#
# API de pe telefon:
# - USB + adb reverse: EXPO_PUBLIC_API_URL=http://127.0.0.1:3001
#   Rulează: adb reverse tcp:3001 tcp:3001
# - Aceeași Wi-Fi: IP-ul Mac-ului (același prefix ca în Metro), ex. http://192.168.100.52:3001
# Backend trebuie să asculte pe 0.0.0.0:3001 (nu doar localhost), dacă folosești IP LAN.

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_URL=http://127.0.0.1:3001
