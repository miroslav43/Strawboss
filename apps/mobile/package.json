{
  "name": "@strawboss/mobile",
  "version": "0.0.1",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "dotenv -e .env.dev -- expo start",
    "build:android": "eas build --platform android --profile apk",
    "build:android:local": "dotenv -e .env.dev -- sh -c \"expo prebuild --platform android && cd android && ./gradlew assembleDebug\"",
    "build:apk": "dotenv -e .env.production -- sh -c \"expo prebuild --clean --platform android && cd android && ./gradlew assembleDebug\"",
    "build:ios": "eas build --platform ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app/ src/",
    "android": "dotenv -e .env.dev -- expo run:android",
    "ios": "dotenv -e .env.dev -- expo run:ios"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-community/netinfo": "^11.4.1",
    "@strawboss/api": "workspace:*",
    "@strawboss/types": "workspace:*",
    "@strawboss/ui-tokens": "workspace:*",
    "@strawboss/validation": "workspace:*",
    "@supabase/supabase-js": "^2.47.0",
    "@tanstack/react-query": "^5.62.0",
    "expo": "~54.0.0",
    "expo-background-task": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.21",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-location": "^55.1.4",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-signature-canvas": "^4.7.0",
    "react-native-webview": "~13.13.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.17",
    "dotenv-cli": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
