# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public URL of the Nest API (origin only, no trailing slash).
# Production build: baked into the Next.js client bundle — must be the URL browsers use.
NEXT_PUBLIC_API_URL=https://your-domain.com

# Local Android APK: ./strawboss.sh mobile-build-local (optional if SDK is not under ~/Android/Sdk)
# ANDROID_HOME=/root/Android/Sdk

# Dev-only: URL the Next.js dev server proxies /api/v1/* to (avoids CORS).
# Defaults to http://localhost:3001 so undeployed endpoints (e.g. new routes) work locally.
# Override only if you want to test against a remote backend during development.
# NEXT_DEV_API_PROXY_URL=http://localhost:3001

# Email for Let's Encrypt certificate notifications (used by ssl:init).
CERTBOT_EMAIL=your-email@example.com

# Optional: directory for rotated JSON logs (web/ and mobile/ subtrees). Docker sets /app/logs.
# LOG_ROOT=/srv/apps/Strawboss/logs
