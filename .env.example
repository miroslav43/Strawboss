# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public URL of the Nest API as seen by the browser (baked into admin at build time).
# Production: https://your-domain.com (or same origin if you reverse-proxy /api).
# Local docker (admin :3000 → API :3001): http://localhost:3001
NEXT_PUBLIC_API_URL=https://your-domain.com

# Email for Let's Encrypt certificate notifications (used by ssl:init).
CERTBOT_EMAIL=your-email@example.com
